---
layout: layouts/base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time>
  </header>

  <div class="post-grid">
    <div class="post-body">
      {{ content | safe }}
    </div>

    <aside class="post-toc" aria-label="Table of contents">
      <p class="toc-label">On this page</p>
      {{ content | toc | safe }}
    </aside>
  </div>
</article>
